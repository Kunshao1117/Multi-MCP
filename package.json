{
  "name": "multi-mcp-gateway",
  "version": "1.0.0",
  "description": "統一 MCP 閘道器 — 單一插槽代理多個下游 MCP 伺服器",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "multi-mcp-gateway": "dist/index.js"
  },
  "files": [
    "dist/**",
    "mcp-catalog.json",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\" && tsc",
    "typecheck": "tsc --noEmit --pretty false",
    "start": "node dist/index.js",
    "scan": "node dist/index.js --scan",
    "console": "tsx src/cli.ts",
    "dev": "tsx src/index.ts",
    "dev:scan": "tsx src/index.ts --scan",
    "test": "vitest run src",
    "test:watch": "vitest src",
    "verify:runtime": "node scripts/verify-gateway-runtime.mjs",
    "preflight:gateway": "npm run typecheck && vitest run src/paths.test.ts src/config-loader.test.ts src/process-pool.test.ts src/registry.test.ts src/tool-router.test.ts src/runtime-guard.test.ts && npm run build && npm run verify:runtime"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
