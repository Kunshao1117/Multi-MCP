{
  "name": "multi-mcp-gateway",
  "version": "0.1.0",
  "description": "統一 MCP 閘道器 — 單一插槽代理多個下游 MCP 伺服器",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "scan": "node dist/index.js --scan",
    "console": "tsx src/cli.ts",
    "dev": "tsx src/index.ts",
    "dev:scan": "tsx src/index.ts --scan",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1"
  },
  "devDependencies": {
    "@types/node": "^22.13.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
